{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "path",
          "style": "plain",
          "foreground": "cyan",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3
          },
          "template": "{{ .Path }} "
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "magenta",
          "properties": {
            "fetch_status": true,
            "branch_icon": " "
          },
          "template": "on {{ .HEAD }}{{ if .Working.Changed }}*{{ end }} "
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "yellow",
          "properties": {
            "threshold": 2000,
            "style": "round"
          },
          "template": "took {{ .FormattedMs }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground_templates": [
            "{{ if gt .Code 0 }}red{{ else }}green{{ end }}"
          ],
          "template": "❯"
        }
      ]
    }
  ]
}
